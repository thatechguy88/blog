---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import jellyIcon from '../assets/icon-jelly.png';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="aero-pane">
				<div class="glossy-header">
					<h1>
						<Image src={jellyIcon} alt="" width="48" height="48" style="vertical-align: middle; margin-right: 12px;" />
						Welcome to Justin's Digital Oasis
					</h1>
				</div>
				<div class="aero-content">
					<p>
						Hello, world! 👋 This is my corner of the web, currently undergoing a transformation 
						into a <strong>Frutiger Aero</strong> paradise.
					</p>
					<p>
						Inspired by the optimistic design of the mid-2000s, this site celebrates 
						glossy gradients, glass textures, and the spirit of a more colorful web.
					</p>
					
					<h3>Current Experiments:</h3>
					<ul>
						<li><strong>Aero Glass:</strong> Implementing real-time background blurring using modern CSS.</li>
						<li><strong>Optimistic UI:</strong> Bringing back the vibrant blues and greens of the Vista/7 era.</li>
						<li><strong>Content Migration:</strong> Porting my thoughts from the old "JustinOS" into this new, glossy world.</li>
					</ul>
					
					<p>
						Feel free to explore the <a href="/blog/">📝 Blog</a> to see the latest updates 
						or check out some of the migrated posts from my previous retro site.
					</p>
					
					<hr />
					<p>
						<em>Stay tuned for more gloss, more glass, and more optimism.</em>
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
