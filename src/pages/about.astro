---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts';
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About Justin Liu" description={SITE_DESCRIPTION} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 16px;
				box-shadow: var(--box-shadow);
			}
			.bio {
				font-size: 1.15rem;
				line-height: 1.7;
				color: #222;
			}
			.bio strong {
				color: #000;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="aero-pane">
				<div class="glossy-header">
					<h1>Justin Liu</h1>
				</div>
				<div class="aero-content">
					<div class="hero-image">
						<Image src={AboutHeroImage} alt="" width={1020} height={510} />
					</div>
					<div class="bio">
						<p>
							I work in <strong>autonomous vehicle tech</strong> — running in-vehicle tests and keeping the stack alive: networking, servers, and the cars themselves.
							For me, tech isn't just a job. It's the foundation everything else is built on this generation. <strong>Building is how I express.</strong>
						</p>
						
						<p>
							I've spent years studying design, arts, and cinematography — and all of it feeds into how I think about what I make.
							I believe you have to love what you do. That's not a slogan; it's a filter.
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
